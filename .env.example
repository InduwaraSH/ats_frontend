# Copy this file to .env and fill in the values.
#
# In development: keep /api/v1 — the Vite proxy (vite.config.ts) forwards
# all /api/* requests to http://localhost:8000.
#
# In production: set the full backend origin, e.g.
#   VITE_API_BASE_URL=https://api.yourapp.com/api/v1
VITE_API_BASE_URL=/api/v1
